/*
Missing Number

Problem:
An array contains n distinct numbers from 0 to n, but one number is missing.

Find the missing number.

Example:
Input:
[3,0,1]

Output:
2
*/

import java.util.*;

public class MissingNumber {

  static int miss(int[] a) {
    int x=a.length;

    for(int i=0;i<a.length;i++) {
      x^=i;
      x^=a[i];
    }

    return x;
  }

  public static void main(String[] args) {
    Scanner sc=new Scanner(System.in);

    int n=sc.nextInt();
    int[] a=new int[n];

    for(int i=0;i<n;i++)
      a[i]=sc.nextInt();

    System.out.println(miss(a));
  }
}
